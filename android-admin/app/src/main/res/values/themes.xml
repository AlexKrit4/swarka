<resources>
    <style name="Theme.SwarkaAdmin" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#1A1714</item>
        <item name="colorPrimaryVariant">#1A1714</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#F7E018</item>
        <item name="colorOnSecondary">#1A1714</item>
        <item name="android:statusBarColor">#1A1714</item>
        <item name="android:navigationBarColor">#1A1714</item>
        <item name="android:windowBackground">#1A1714</item>
    </style>

    <style name="Theme.SwarkaAdmin.Splash" parent="Theme.SwarkaAdmin">
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="PinButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="strokeColor">#3A3530</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>
</resources>
