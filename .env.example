# Database (Docker Compose sets this for the api service)
DATABASE_URL=postgresql://swarka:CHANGE_DB_PASSWORD@postgres:5432/swarka

# API
API_PORT=4000
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
# Until SSL is ready use http:// ; after SSL switch to https://
CORS_ORIGINS=http://swarka-i-voditel.ru,http://www.swarka-i-voditel.ru,http://admin.swarka-i-voditel.ru
UPLOADS_DIR=/app/uploads

# Admin seed (first deploy)
ADMIN_EMAIL=admin@swarka-i-voditel.ru
ADMIN_PASSWORD=change-me-strong-password

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Public URLs (baked into Next.js at build time). Use http until SSL.
NEXT_PUBLIC_API_URL=http://api.swarka-i-voditel.ru
NEXT_PUBLIC_SITE_URL=http://swarka-i-voditel.ru

# Yandex Metrika (optional)
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# Postgres password used by docker-compose (must match DATABASE_URL)
POSTGRES_PASSWORD=CHANGE_DB_PASSWORD
